# Aggiunto da MauAGA per i soliti alias
alias cp="cp -i"
alias mv="mv -i"
alias rm="rm -i"
alias ll="ls -la --color=auto"

# Inserito da MauAGA per colorare prompt di root
# export PS1='\[\033[0;31m\]\u@\[\033[1;34m\h:\[\033[1;31m\]\w\[\033[0;31m\]\$\[\033[0m\] '

# Inserito da MauAGA per colorare di verde e altro il prompt di root
export PS1="\[\e[32;1m\]\u@\h\[\e[0m\]:\[\e[34;1m\]\w\[\e[0m\]\$ "
